@model User2
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow-sm p-4 border rounded bg-light">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-info m-0">Create User</h2>
                <a href="/Users/Index" class="btn btn-sm btn-outline-info">&larr; Back</a>
            </div>

            <form method="post" action="/Users/Store">
            <div class="mb-3">
                    <label for="name" class="form-label">Full Name</label>
                    <input type="text" value="@Model.Name" id="name" name="Name" class="form-control" placeholder="Enter name" />
                    <span class="text-danger" asp-validation-for="Name"></span>

                </div>

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <input type="email" value="@Model.Email" id="email" name="Email" class="form-control" placeholder="name@example.com" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="age" class="form-label">Age</label>
                        <input type="number" id="age" value="@(Model.Age == 0 ? "" : Model.Age)" name="Age" class="form-control" />
                        <span class="text-danger" asp-validation-for="Age"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="score" class="form-label">Score</label>
                        <input type="number" id="score" value="@Model.Score" name="Score" class="form-control" />
                         <span class="text-danger" asp-validation-for="Score"></span>
                    </div>
                </div>
                
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-info text-white mt-2">Create User</button>
                </div>
            </form>
        </div>
    </div>
</div>