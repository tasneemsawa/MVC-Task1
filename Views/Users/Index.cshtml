@using WebApplication1.Models
@model List<User2>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-info fw-bold">All Users</h1>
        <a href="/Users/Create" class="btn btn-info text-white shadow-sm fw-semibold">
            <i class="bi bi-person-plus-fill me-1"></i> Add New User
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center shadow-sm">
            <h4>No Users Found!</h4>
            <p>Try adding some users to see them listed here.</p>
        </div>
    }
    else
    {
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-4">Name</th>
                                <th>Email</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-secondary ps-4">@user.Name</td>
                                    <td>@user.Email</td>
                                    <td class="text-end pe-4">
                                        <div class="d-inline-flex gap-2">
                                            <a href="/Users/Details/@user.Id" class="btn btn-outline-info rounded-2"
                                               title="Details">
                                                <i class="bi bi-eye"></i> <span class="d-none d-md-inline ms-1">Details</span>
                                            </a>

                                            <a href="/Users/Edit/@user.Id" class="btn btn-outline-warning rounded-2"
                                               title="Edit">
                                                <i class="bi bi-pencil"></i> <span class="d-none d-md-inline ms-1">Edit</span>
                                            </a>

                                            <a href="/Users/Delete/@user.Id" class="btn btn-outline-danger rounded-2"
                                               title="Delete">
                                                <i class="bi bi-trash"></i> <span class="d-none d-md-inline ms-1">Delete</span>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>