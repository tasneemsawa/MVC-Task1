@model User2

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-5" style="max-width: 700px;">
    
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <h1 class="text-info fw-bold mb-1">
                <i class="bi bi-pencil-square me-2"></i>Edit User
            </h1>
            <p class="text-muted small mb-0">Modify user details and update their permissions.</p>
        </div>
        
        <a href="/Users/Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3 shadow-sm text-decoration-none d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="bg-white p-4 p-md-5 rounded-4 shadow-sm border border-light-subtle">
        <form method="post" action="/Users/Update">
            <input type="hidden" name="Id" value="@Model.Id" />

            <div class="mb-4">
                <label class="form-label fw-semibold text-secondary small text-uppercase mb-2">Full Name</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-muted border-end-0 border-light-subtle"><i class="bi bi-person"></i></span>
                    <input type="text" name="Name" value="@Model.Name" class="form-control bg-light-subtle border-start-0 ps-0 text-secondary fw-bold border-light-subtle" placeholder="Enter Name" required />
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold text-secondary small text-uppercase mb-2">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light text-muted border-end-0 border-light-subtle"><i class="bi bi-envelope"></i></span>
                    <input type="email" name="Email" value="@Model.Email" class="form-control bg-light-subtle border-start-0 ps-0 border-light-subtle" placeholder="Enter Email" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label fw-semibold text-secondary small text-uppercase mb-2">Age</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0 border-light-subtle"><i class="bi bi-calendar-event"></i></span>
                        <input type="number" name="Age" value="@Model.Age" class="form-control bg-light-subtle border-start-0 ps-0 border-light-subtle" placeholder="Age" required />
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <label class="form-label fw-semibold text-secondary small text-uppercase mb-2">User Score</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-info border-end-0 border-light-subtle"><i class="bi bi-trophy-fill"></i></span>
                        <input type="number" name="Score" value="@Model.Score" class="form-control bg-light-subtle border-start-0 ps-0 border-light-subtle" placeholder="Score" required />
                    </div>
                </div>
            </div>

            <div class="border-top border-light-subtle my-4"></div>
            <div class="d-flex justify-content-end gap-2">
                <a href="/Users/Index" class="btn btn-light text-secondary border px-4 rounded-3 fw-medium">
                    Cancel
                </a>
                <button type="submit" class="btn btn-info text-white px-4 rounded-3 fw-semibold shadow-sm">
                    <i class="bi bi-check-circle-fill me-1"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>